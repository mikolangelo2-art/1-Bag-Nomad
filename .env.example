# Server-side only (Vercel ? Environment Variables). Used by api/unsplash.js — never exposed to the browser.
UNSPLASH_ACCESS_KEY=

# Vercel serverless (api/ask.js, api/airports.js)
ANTHROPIC_API_KEY=
AIRLABS_API_KEY=

# Foursquare Places API v3 (api/foursquare.js) — raw key in Authorization header, no "Bearer" prefix
FOURSQUARE_API_KEY=

# Optional: when running `npm run dev`, proxy /api/* to production so local UI can call APIs
# VITE_API_PROXY=https://1bagnomad.com
